<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Recode.Controls.EnumSelector"
             x:CompileBindings="False">
  <Panel>
    <ListBox x:Name="ItemsListBox" SelectionMode="Single" Background="Transparent">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Padding" Value="12,4" />
          <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
      </ListBox.Styles>
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="0" />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <ComboBox x:Name="ItemsComboBox" IsVisible="False">
      <ComboBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>
  </Panel>
</UserControl>