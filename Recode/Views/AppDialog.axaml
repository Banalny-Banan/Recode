<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Recode.Views.AppDialog"
        Width="400" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <StackPanel Margin="24" Spacing="16">
    <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="PrimaryButton" MinWidth="80" HorizontalContentAlignment="Center" IsVisible="False" />
      <Button x:Name="SecondaryButton" MinWidth="80" HorizontalContentAlignment="Center" IsVisible="False" />
    </StackPanel>
  </StackPanel>

</Window>