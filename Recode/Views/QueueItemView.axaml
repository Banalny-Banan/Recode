<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Recode.ViewModels"
             xmlns:controls="clr-namespace:Recode.Controls"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="24"
             x:Class="Recode.Views.QueueItemView"
             x:DataType="vm:QueueItemViewModel"
             ClipToBounds="True">

  <Grid Margin="8,4" ColumnSpacing="4" MinHeight="20" ToolTip.Tip="{Binding ErrorMessage}" Background="Transparent">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="3*" />
      <ColumnDefinition Width="*" MaxWidth="200" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding FileName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
      <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
    </Grid>

    <controls:SmoothProgressBar Grid.Column="1" Value="{Binding Progress}" Foreground="{Binding ProgressBarBrush}" MinWidth="70" VerticalAlignment="Center" Margin="4" />

    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Stretch" Margin="0,-2">
      <StackPanel.Styles>
        <Style Selector="Button">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        </Style>
        <Style Selector="TextBlock.check-icon">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="RenderTransform" Value="scale(0.7)" />
        </Style>
        <Style Selector="Button.copied TextBlock.copy-icon">
          <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Button.copied TextBlock.check-icon">
          <Setter Property="Opacity" Value="1" />
          <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>
      </StackPanel.Styles>

      <Grid Width="28" VerticalAlignment="Stretch">
        <Button FontFamily="Segoe Fluent Icons"
                Width="28" Padding="0" FontSize="14" CornerRadius="4,0,0,4"
                VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                IsVisible="{Binding !CanRetry}" IsEnabled="{Binding CanCopy}"
                Click="CopyButton_OnClick" ToolTip.Tip="Copy to clipboard">
          <Grid>
            <TextBlock Classes="copy-icon" Text="&#xE8C8;" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </TextBlock.Transitions>
            </TextBlock>
            <TextBlock Classes="check-icon" Text="&#xE73E;" HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
              <TextBlock.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                  <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                </Transitions>
              </TextBlock.Transitions>
            </TextBlock>
          </Grid>
        </Button>
        <Button Content="&#xE72C;" FontFamily="Segoe Fluent Icons"
                Width="28" Padding="0" FontSize="14" CornerRadius="4,0,0,4"
                VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                IsVisible="{Binding CanRetry}"
                Command="{Binding RetryCommand}" ToolTip.Tip="Retry" />
      </Grid>

      <Button Content="&#xE74D;" FontFamily="Segoe Fluent Icons"
              Width="28" Padding="0" FontSize="14" CornerRadius="0,4,4,0"
              VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
              Click="RemoveButton_OnClick" ToolTip.Tip="Remove" />

    </StackPanel>
  </Grid>

</UserControl>
