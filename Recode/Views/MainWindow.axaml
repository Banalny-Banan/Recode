<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Recode.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Recode.Views"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="375"
        Width="600" Height="370" MinWidth="600" MinHeight="375"
        x:Class="Recode.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Recode"
        RequestedThemeVariant="Light">

  <Window.Background>
    <DynamicResourceExtension ResourceKey="AppBackgroundBrush" />
  </Window.Background>

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
    <views:FileDropZone Grid.Row="0" Margin="0,0,0,16" />
    <views:CompressionControls Grid.Row="1" />
    <views:FileQueue Grid.Row="2" />
    <views:ControlBar Grid.Row="3" Margin="0,8,0,0" />
  </Grid>

</Window>