<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Recode.ViewModels"
             mc:Ignorable="d" d:DesignWidth="568" d:DesignHeight="92"
             x:Class="Recode.Views.FileQueue"
             x:DataType="vm:MainWindowViewModel">

  <Grid RowDefinitions="*,Auto" RowSpacing="4">

    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            Background="{DynamicResource AppInsetBrush}"
            BorderThickness="1,1,1,1" CornerRadius="4,4,0,0" Padding="0">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">

        <ItemsControl ItemsSource="{Binding QueueItems}" Grid.IsSharedSizeScope="True">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:QueueItemViewModel">
              <Grid Margin="8,4" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="3*" />
                  <ColumnDefinition Width="Auto" MinWidth="150" SharedSizeGroup="Size" />
                  <ColumnDefinition Width="*" MaxWidth="200" />
                  <ColumnDefinition Width="74" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FileName}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                <ProgressBar Grid.Column="2" Value="{Binding Progress}" MinWidth="70" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="{Binding Status}" VerticalAlignment="Center" HorizontalAlignment="Center" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </ScrollViewer>
    </Border>

    <ProgressBar Grid.Row="1" Value="{Binding OverallProgress}" MinHeight="6" CornerRadius="0,0,4,4" />

  </Grid>

</UserControl>