<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Recode.ViewModels"
             xmlns:views="clr-namespace:Recode.Views"
             xmlns:controls="clr-namespace:Recode.Controls"
             mc:Ignorable="d" d:DesignWidth="568" d:DesignHeight="150"
             x:Class="Recode.Views.FileQueue"
             x:DataType="vm:MainWindowViewModel">

  <Grid RowDefinitions="*,Auto" RowSpacing="4">

    <Border BorderBrush="{DynamicResource AppBorderBrush}" Background="{DynamicResource AppInsetBrush}"
            BorderThickness="1" CornerRadius="4,4,0,0" Padding="0,2" DragDrop.AllowDrop="True">

      <controls:SmoothScrollViewer HorizontalScrollBarVisibility="Disabled" ScrollStep="45" Margin="0,0,2,0" Padding="0,0,2,0">

        <controls:SmoothScrollViewer.Styles>
          <Style Selector="RepeatButton">
            <Setter Property="IsVisible" Value="False" />
          </Style>
          <Style Selector="ScrollBar">
            <Setter Property="AllowAutoHide" Value="False" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Width" Value="8" />
          </Style>
          <Style Selector="Thumb">
            <Setter Property="Template">
              <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="3" Width="6" />
              </ControlTemplate>
            </Setter>
          </Style>
        </controls:SmoothScrollViewer.Styles>

        <DockPanel MinHeight="{Binding $parent[controls:SmoothScrollViewer].Viewport.Height}">
          <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding QueueItems}" Grid.IsSharedSizeScope="True">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:QueueItemViewModel">
                <views:QueueItemView />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border x:Name="BrowseContainer" Background="Transparent" Padding="0,0,0,6"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Cursor="Hand" PointerPressed="BrowseButton_OnClick">
            <TextBlock Text="Drop files here or click to browse"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock.Styles>
                <Style Selector="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource AppTextDisabledBrush}" />
                </Style>
                <Style Selector="Border#BrowseContainer:pointerover TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
                </Style>
              </TextBlock.Styles>
            </TextBlock>
          </Border>

        </DockPanel>

      </controls:SmoothScrollViewer>

    </Border>

    <controls:SmoothProgressBar Grid.Row="1" Value="{Binding OverallProgress}" MinHeight="6" CornerRadius="0,0,4,4" />

  </Grid>

</UserControl>