<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Recode.ViewModels"
             xmlns:controls="clr-namespace:Recode.Controls"
             mc:Ignorable="d" d:DesignWidth="568" d:DesignHeight="70"
             x:Class="Recode.Views.CompressionControls"
             x:DataType="vm:MainWindowViewModel">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">

    <!-- Codec selector -->
    <TextBlock Grid.Row="0" Grid.Column="0" Text="Codec:" VerticalAlignment="Center" Width="60" />
    <controls:EnumSelector Grid.Row="0" Grid.Column="1" SelectedValue="{Binding SelectedCodec}" Mode="List" />

    <!-- Quality slider -->
    <TextBlock Grid.Row="1" Grid.Column="0" Text="Quality:" VerticalAlignment="Center" Width="60" />
    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
      <Slider Minimum="0" Maximum="100" Value="{Binding QualityValue}" Width="300" VerticalAlignment="Center" ToolTip.Tip="{Binding QualityLabel}" />
    </StackPanel>

  </Grid>
</UserControl>