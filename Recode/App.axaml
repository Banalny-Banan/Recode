<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Recode.App"
             xmlns:local="using:Recode"
             RequestedThemeVariant="Default">
  <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <!-- Background -->
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF3F3F3" />
          <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />

          <!-- Accent -->
          <SolidColorBrush x:Key="AppAccentBrush" Color="#FF005FB8" />
          <SolidColorBrush x:Key="AppAccentHoverBrush" Color="#FF1971C2" />
          <SolidColorBrush x:Key="AppAccentPressedBrush" Color="#FF004E99" />
          <SolidColorBrush x:Key="AppAccentDisabledBrush" Color="#55005FB8" />

          <!-- Text -->
          <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#FF1A1A1A" />
          <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#FF656565" />
          <SolidColorBrush x:Key="AppTextDisabledBrush" Color="#FF9E9E9E" />
          <SolidColorBrush x:Key="AppTextOnAccentBrush" Color="#FFFFFFFF" />

          <!-- Border -->
          <SolidColorBrush x:Key="AppBorderBrush" Color="#FFD6D6D6" />

          <!-- Status -->
          <SolidColorBrush x:Key="AppErrorBrush" Color="#FFC42B1C" />
          <SolidColorBrush x:Key="AppSuccessBrush" Color="#FF0F7B0F" />
          <SolidColorBrush x:Key="AppWarningBrush" Color="#FF9D5D00" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <!-- Background -->
          <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF1C1C1E" />
          <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF2A2A2C" />

          <!-- Accent -->
          <SolidColorBrush x:Key="AppAccentBrush" Color="#FF4CC2FF" />
          <SolidColorBrush x:Key="AppAccentHoverBrush" Color="#FF5ECAFF" />
          <SolidColorBrush x:Key="AppAccentPressedBrush" Color="#FF38B4F0" />
          <SolidColorBrush x:Key="AppAccentDisabledBrush" Color="#554CC2FF" />

          <!-- Text -->
          <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#FFE4E4E4" />
          <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#FF9D9D9D" />
          <SolidColorBrush x:Key="AppTextDisabledBrush" Color="#FF5C5C5C" />
          <SolidColorBrush x:Key="AppTextOnAccentBrush" Color="#FF000000" />

          <!-- Border -->
          <SolidColorBrush x:Key="AppBorderBrush" Color="#FF3D3D3D" />

          <!-- Status -->
          <SolidColorBrush x:Key="AppErrorBrush" Color="#FFFF6B68" />
          <SolidColorBrush x:Key="AppSuccessBrush" Color="#FF4EC96B" />
          <SolidColorBrush x:Key="AppWarningBrush" Color="#FFFFB848" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>